# Website & Backend Environment Variables Example
# Copy this file to .env and fill in the values

# --- Frontend (Vite) ---
# Gemini API Key for AI features (search, chat, etc.)
GEMINI_API_KEY="your_gemini_api_key_here"

# Backend API URL (for production, use the deployed backend URL)
# Default for local development: http://localhost:5000
VITE_API_URL="http://localhost:5000"

# --- Firebase (Frontend) ---
VITE_FIREBASE_API_KEY="your_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your_project_id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your_project_id"
VITE_FIREBASE_STORAGE_BUCKET="your_project_id.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_sender_id"
VITE_FIREBASE_APP_ID="your_app_id"
VITE_FIREBASE_MEASUREMENT_ID="your_measurement_id"

# --- Backend (Express) ---
# Port for the backend server


# Node Environment (production, development)
NODE_ENV="development"

# Firebase Service Account JSON (stringified)
# Required for Firestore and Auth operations
# Format: {"type": "service_account", "project_id": "...", ...}
FIREBASE_SERVICE_ACCOUNT='{"your": "service_account_json_content_here"}'

# --- Deployment ---
# Base URL for the application
APP_URL="http://localhost:5173"
